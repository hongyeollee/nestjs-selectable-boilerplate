{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["tools/schematics/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
